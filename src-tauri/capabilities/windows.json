{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "windows-drives",
  "description": "Windows drive letter filesystem permissions. Separated from default.json because backslash-glob patterns (C:\\**) cause 'invalid glob pattern' errors on Unix where backslash is not a path separator.",
  "windows": ["main", "doc-*"],
  "platforms": ["windows"],
  "permissions": [
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "C:\\**" },
        { "path": "D:\\**" },
        { "path": "E:\\**" },
        { "path": "F:\\**" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "C:\\**" },
        { "path": "D:\\**" },
        { "path": "E:\\**" },
        { "path": "F:\\**" }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "C:\\**" },
        { "path": "D:\\**" },
        { "path": "E:\\**" },
        { "path": "F:\\**" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "C:\\**" },
        { "path": "D:\\**" },
        { "path": "E:\\**" },
        { "path": "F:\\**" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "C:\\**" },
        { "path": "D:\\**" },
        { "path": "E:\\**" },
        { "path": "F:\\**" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "C:\\**" },
        { "path": "D:\\**" },
        { "path": "E:\\**" },
        { "path": "F:\\**" }
      ]
    },
    {
      "identifier": "fs:allow-copy-file",
      "allow": [
        { "path": "C:\\**" },
        { "path": "D:\\**" },
        { "path": "E:\\**" },
        { "path": "F:\\**" }
      ]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "C:\\**" },
        { "path": "D:\\**" },
        { "path": "E:\\**" },
        { "path": "F:\\**" }
      ]
    },
    {
      "identifier": "fs:allow-rename",
      "allow": [
        { "path": "C:\\**" },
        { "path": "D:\\**" },
        { "path": "E:\\**" },
        { "path": "F:\\**" }
      ]
    }
  ]
}
