{
  "enabled": true,
  "testCommand": "pnpm test",
  "coverageCommand": "pnpm test:coverage",
  "coverageSummaryPath": "coverage/coverage-summary.json",
  "mutationCommand": "",
  "thresholds": {
    "lines": 100,
    "functions": 100,
    "branches": 100,
    "statements": 100
  },
  "enforceRedGreenRefactor": true,
  "blockCommitOnFailure": true,
  "stack": "react-ts-vitest",
  "packageManager": "pnpm"
}
